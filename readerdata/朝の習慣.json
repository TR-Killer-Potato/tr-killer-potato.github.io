{
    "title": "朝の習慣 (Morning Routine)",
    "content": "私は毎朝六時に**起きます**。それから、**コーヒー**を飲みます。朝ご飯はたいてい**パン**を食べます。七時半に**会社**へ行きます。仕事は大変ですが、**面白い**です。",
    "vocabulary": {
        "起きます": {
            "reading": "おきます",
            "meaning": "To wake up"
        },
        "コーヒー": {
            "reading": "こーひー",
            "meaning": "Coffee"
        },
        "パン": {
            "reading": "ぱん",
            "meaning": "Bread"
        },
        "会社": {
            "reading": "かいしゃ",
            "meaning": "Company / Office"
        },
        "面白い": {
            "reading": "おもしろい",
            "meaning": "Interesting / Fun"
        }
    }
}
